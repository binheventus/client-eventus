{
  "name": "client-eventus",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config apps/web/vite.config.js",
    "dev:background": "node scripts/manage-dev-server.mjs start",
    "dev:status": "node scripts/manage-dev-server.mjs status",
    "dev:stop": "node scripts/manage-dev-server.mjs stop",
    "dev:web": "vite --config apps/web/vite.config.js",
    "build": "vite --config apps/web/vite.config.js build",
    "db:migrate": "node scripts/migrate-mysql.mjs",
    "feedback:import-legacy": "node scripts/import-feedback-legacy.mjs",
    "feedback:prune": "node scripts/prune-feedback-data.mjs",
    "feedback:cleanup-attachments": "node scripts/cleanup-feedback-attachments.mjs",
    "pricing:export": "node scripts/export-pricing-from-google-sheet.mjs",
    "pricing:seed": "node scripts/seed-pricing-mysql.mjs",
    "test:quotes": "node --test apps/web/src/features/quotes/lib/*.test.js apps/api/*.test.js",
    "preview": "vite --config apps/web/vite.config.js preview",
    "start": "node apps/api/server.js",
    "start:api": "node apps/api/server.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.21",
    "@nestjs/core": "^11.1.21",
    "@nestjs/platform-express": "^11.1.21",
    "@react-pdf/renderer": "^4.5.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.400.0",
    "mysql2": "^3.22.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0"
  }
}
