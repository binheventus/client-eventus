# Claude AI parser
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.coffeevibeai.com
QUOTE_PARSE_AI_MODEL=claude-haiku-4-5-20251001
QUOTE_PARSE_AI_TIMEOUT_MS=20000
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Laravel auth source for protected /quotes pages and APIs.
EVENTUS_AUTH_BASE_URL=https://lichlamviec.eventusproduction.com
EVENTUS_AUTH_ME_PATH=/api/auth/me
EVENTUS_AUTH_LOGIN_URL=https://lichlamviec.eventusproduction.com/login
EVENTUS_AUTH_TIMEOUT_MS=5000
# Set to 1 only for isolated local development/tests.
EVENTUS_AUTH_DISABLED=0

# Feedback module integrations.
# Feedback image uploads are stored on the current server.
# Defaults to ./storage/feedback-assets/uploads for local/dev.
FEEDBACK_UPLOAD_ROOT=
FEEDBACK_UPLOAD_PUBLIC_PREFIX=/feedback-assets/uploads
FEEDBACK_ATTACHMENT_TTL_DAYS=20
FEEDBACK_IMAGE_MAX_COUNT=4
FEEDBACK_IMAGE_MAX_BYTES=3145728
VITE_FEEDBACK_IMAGE_MAX_COUNT=4
VITE_FEEDBACK_IMAGE_MAX_EDGE=1600
VITE_FEEDBACK_IMAGE_MAX_BYTES=3145728
# Optional video helpers for YouTube metadata and timeline screenshots.
YT_DLP_BIN=
FFMPEG_BINARIES=ffmpeg
# Eventus HR/notification API base URL.
NHANSU_URL=

# Only needed when exporting pricing JSON from a private Google Sheet.
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=
PRICING_SPREADSHEET_ID=

# Trợ lý feedback AI (tùy chọn) — mặc định trùng quote parser khi để trống.
# Dùng chung ANTHROPIC_API_KEY / ANTHROPIC_BASE_URL với quote parser.
FEEDBACK_SUMMARY_AI_MODEL=claude-haiku-4-5-20251001
FEEDBACK_SUMMARY_AI_TIMEOUT_MS=20000
GALLERY_GAS_URL=https://script.google.com/macros/s/AKfycbzAJIv0r9pQbjsnhcKs02YJX-eqTAjT7jlkVHtLsplc9Ro58hPQYC3ZcLF1TZ5T-rU/exec
GALLERY_GAS_TIMEOUT_MS=8000
